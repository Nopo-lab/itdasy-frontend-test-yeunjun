<?xml version="1.0" encoding="UTF-8"?>
<!-- 잇데이 iOS Info.plist 권한 블록 (T-318 · 2026-04-22)

     Xcode → Info.plist 의 <dict> 안에 아래 키들을 추가.
     기존 Capacitor 기본 키는 유지하고 "Custom iOS Target Properties" 에 추가.
-->
<dict>
  <!-- 카메라 -->
  <key>NSCameraUsageDescription</key>
  <string>시술 사진을 촬영하거나 고객 정보 스크린샷을 불러오기 위해 카메라를 사용합니다.</string>

  <!-- 사진첩 읽기 -->
  <key>NSPhotoLibraryUsageDescription</key>
  <string>시술 전·후 사진을 포트폴리오에 추가하고 인스타그램에 발행하기 위해 사진첩에 접근합니다.</string>

  <!-- 사진첩 저장 -->
  <key>NSPhotoLibraryAddUsageDescription</key>
  <string>AI 가 생성한 스토리 이미지를 저장하기 위해 사진첩에 접근합니다.</string>

  <!-- 마이크 -->
  <key>NSMicrophoneUsageDescription</key>
  <string>음성으로 고객·매출·예약을 빠르게 기록하기 위해 마이크를 사용합니다.</string>

  <!-- Face ID -->
  <key>NSFaceIDUsageDescription</key>
  <string>비밀번호 대신 Face ID 로 빠르게 로그인하기 위해 사용합니다.</string>

  <!-- 주소록 (선택) -->
  <key>NSContactsUsageDescription</key>
  <string>기존 고객 연락처를 잇데이로 이전하기 위해 주소록에 접근합니다.</string>

  <!-- 추적 (사용 안 함 — 명시) -->
  <key>NSUserTrackingUsageDescription</key>
  <string>잇데이는 사용자 추적을 하지 않습니다.</string>

  <!-- App Transport Security — Capacitor 기본 HTTPS 강제 사용 -->
  <key>NSAppTransportSecurity</key>
  <dict>
    <key>NSAllowsArbitraryLoads</key>
    <false/>
  </dict>

  <!-- 화면 방향: 세로만 (1인샵 원장님 한 손 사용) -->
  <key>UISupportedInterfaceOrientations</key>
  <array>
    <string>UIInterfaceOrientationPortrait</string>
  </array>

  <!-- 상태바 스타일 -->
  <key>UIStatusBarStyle</key>
  <string>UIStatusBarStyleDefault</string>
  <key>UIViewControllerBasedStatusBarAppearance</key>
  <true/>

  <!-- 심사용 — Export Compliance (encryption exempt) -->
  <key>ITSAppUsesNonExemptEncryption</key>
  <false/>
</dict>
